@article{uvarov_development_2023,
	title = {Development and validation of an analytical model of isotope production by bremsstrahlung radiation},
	volume = {199},
	issn = {0969-8043},
	doi = {10.1016/j.apradiso.2023.110890},
	abstract = {An analytical method is used to describe isotope production at an electron accelerator. The key characteristics that determine the total target activity and its distribution have been established. The expressions for the reaction yield depend explicitly on the irradiation regime and parameters of the giant dipole resonance. The model predictions for the bremsstrahlung spectrum and yield of the reference reactions are in good agreement with the results of simulation and experiment.},
