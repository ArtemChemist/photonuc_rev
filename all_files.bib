	doi = {10.1134/S1066362206020184},
	abstract = {Ac-225 was prepared by the Ra-226(gamma, n) reaction on an electron accelerator ({MT}-25 microtron) at {FLNR}. The radiation yield of Ac-225 was 550 Bq/(mu A h mg Ra-226). Ac-225 was isolated from the target material and radioactive impurities by the ion-exchange procedure. The Ac-225 : Ac-227 : Ra-226 activity ratio in the preparation was 1 : similar to 2 x 10(-9) : {\textless}= 6 x 10(-5).},
