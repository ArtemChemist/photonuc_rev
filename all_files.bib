@article{filosofov_potent_2025,
	title = {Potent candidates for Targeted Alpha Therapy ({TAT})},
	volume = {146},
	issn = {0969-8051},
	doi = {10.1016/j.nucmedbio.2025.109027},
	abstract = {Targeted Alpha Therapy ({TAT}) holds significant promise as a localized treatment for cancer. Encouraging clinical results from using peptides and antibodies labeled with alpha emitters to treat patients with metastatic cancers, particularly those who have not responded to other therapies, provide compelling evidence of {TAT}'s potential. To fully realize the benefits of {TAT}, it is essential to carefully select appropriate radionuclides and targeting delivery systems to maximize therapeutic efficacy while minimizing nonspecific toxicity to healthy tissues. This review explores key radiochemical, radiopharmaceutical, and radiation-biological considerations for current {TAT} candidates, and proposes additional potential candidates, establishing a foundation and criteria for the ongoing development of {TAT} radiopharmaceuticals.},
	journaltitle = {{NUCLEAR} {MEDICINE} {AND} {BIOLOGY}},
	author = {Filosofov, Dmitry and Baimukhanova, Ayagoz and Khushvaktov, Jurabek and Kurakina, Elena and Radchenko, Valery},
	urldate = {2025-06-09},
	date = {2025-08},
}

@article{frei_m22-electron_2025,
	title = {M22-the electron accelerator for calibration and research in radiation dosimetry at {METAS}},
	volume = {1077},
	issn = {0168-9002},
	doi = {10.1016/j.nima.2025.170588},
	abstract = {This overview aims to present the metrologically relevant aspects as well as applications beyond conventional radiation dosimetry of the irradiation facility installed at the Swiss Federal Institute of Metrology ({METAS}). The accelerator, based on the microtron principle, can deliver electron beams to three different beamlines. At the treatment head, the properties of the conventional photon and electron radiation field in water have been characterized in terms of quality specifier {TPR}20,10 and R50 respectively. In a second beamline delivering a narrow electron beam, the focus is on the characterization of the beam energy spectrum using a magnetic spectrometer as well as the beam intensity using an absolutely calibrated integrating current transformer. These two components allow the calibration of Fricke solution, a chemical dosimeter to be used as a primary standard for electron beams. In addition to these two long-established beamlines, a recently installed third beamline delivers a narrow electron beam offering great flexibility for exploration. Its use is not limited to ultra-high dose rates but also, for example, to determining the cross sections of photonuclear reactions.},
	journaltitle = {{NUCLEAR} {INSTRUMENTS} \& {METHODS} {IN} {PHYSICS} {RESEARCH} {SECTION} A-{ACCELERATORS} {SPECTROMETERS} {DETECTORS} {AND} {ASSOCIATED} {EQUIPMENT}},
	author = {Frei, Franziska and Voros, Sandor and Luthi, Matthias and Peier, Peter},
	urldate = {2025-05-21},
	date = {2025-08},
}

@article{rasulova_photonuclear_2025,
	title = {Photonuclear reactions on stable isotopes of molybdenum at bremsstrahlung endpoint energies of 10-23 {MeV}},
	volume = {111},
	issn = {2469-9985},
	doi = {10.1103/PhysRevC.111.024604},
	abstract = {In this study experiments were performed at bremsstrahlung end-point energies of 10-23 {MeV} with the beam from the {MT}-25 microtron (Joint Institute for Nuclear Research, Dubna) using the gamma-activation technique. The experimental values of relative yields, cross sections per equivalent quantum and flux-averaged cross sections were compared with theoretical results obtained on the basis of {TALYS}-2.0 code with the standard parameters and the combined model of photonucleon reactions. Including isospin splitting in the combined model of photonucleon reactions allows describing experimental data on reactions with proton escape in the energy range from 15 to 23 {MeV}. Therefore, taking into account isospin splitting is necessary for a correct description of the decay of the giant dipole resonance.},
	number = {2},
	journaltitle = {{PHYSICAL} {REVIEW} C},
	author = {Rasulova, F. A. and Aksenov, V, N. and Alekseev, S. I. and Belyshev, S. S. and Chuprakov, I. and Fursova, N. Yu. and Madumarov, A. S. and Khushvaktov, J. H. and Kuznetsov, A. A.},
	urldate = {2025-03-30},
	date = {2025-02-07},
}

@article{seo_production_2025,
	title = {Production and Supply of Raw Materials for Radiometals used in Radionuclide Imaging and Therapy in Korea},
	volume = {59},
	issn = {1869-3474},
	doi = {10.1007/s13139-025-00907-3},
	abstract = {Radiometals, with their favorable decay properties and rich coordination chemistry, have found widespread applications in both diagnostic and therapeutic nuclear medicine. To ensure effective utilization, radiometal-based radiopharmaceuticals are designed to target specific organs or cells. Radiometals are primarily produced in cyclotrons or reactors using stable isotopes as raw materials. Many countries, including Korea, are pursuing self-sufficiency in radiometal production at the government level. This review examines the current production and supply status of raw materials for key radiometals that are either actively used or expected to see a significant demand growth in the future in Korea.Graphical {AbstractFlow} of radiometal production},
	pages = {103--116},
	number = {2},
	journaltitle = {{NUCLEAR} {MEDICINE} {AND} {MOLECULAR} {IMAGING}},
	author = {Seo, Seok-Jun and Seo, Youngho},
	urldate = {2025-02-10},
	date = {2025-04},
}

@article{tosato_alpha_2025,
	title = {Alpha Atlas: Mapping global production of α-emitting radionuclides for targeted alpha therapy},
	volume = {142},
	issn = {0969-8051},
	doi = {10.1016/j.nucmedbio.2024.108990},
	abstract = {Targeted Alpha Therapy has shown great promise in cancer treatment, sparking significant interest over recent decades. However, its broad adoption has been impeded by the scarcity of alpha-emitters and the complexities related to their use. The availability of these radionuclides is often constrained by the intricate production processes and purification, as well as regulatory and logistical challenges. Moreover, the high cost and technical difficulties associated with handling and applying alpha-emitting radionuclides pose additional barriers to their clinical implementation. This Alpha Atlas provides an in-depth overview of the leading alpha-particle emitting radionuclide candidates for clinical use, focusing on their production processes and supply chains. By mapping the current facilities that produce and supply these radionuclides, this atlas aims to assist researchers, clinicians, and industries in initiating or scaling up the applications of alpha-emitters. The Alpha Atlas aspires to act as a strategic guide, facilitating collaboration and driving forward the integration of these potent therapeutic agents into cancer treatment practices.},
	journaltitle = {{NUCLEAR} {MEDICINE} {AND} {BIOLOGY}},
	author = {Tosato, Marianna and Favaretto, Chiara and Kleynhans, Janke and Burgoyne, Andrew R. and Gestin, Jean-Francois and Meulen, Nicholas P. van der and Jalilian, Amirreza and Koster, Ulli and Asti, Mattia and Radchenko, Valery},
	urldate = {2025-02-21},
	date = {2025-04},
}

@patent{nusair_o_converting_nodate,
	title = {Converting radium to actinium by electron beam            bombardment with high energy electrons without the use            of converter involves bombarding target comprised of            radium present with hermetically sealed capsule with an            electron beam, and maintaining bombardment},
	abstract = {{NOVELTY} - Converting radium (226Ra) to actinium (225Ac)                by electron beam bombardment with high energy                electrons involves (i) bombarding a target                comprised of 226Ra present with hermetically sealed                capsule with an electron beam having an average                effective beam power of about 20-250 kilowatt ({kW})                at a beam energy of about 25-100 Mega electron-volt                ({MeV}), where capsule having a capsule lid through,                which beam of electrons passes prior to impacting                said 226Ra, where the capsule lid optionally having                a high-Z material coating having a thickness of                about 120-220 microns (\&\#956;) on its internal                capsular surface through which beam of electrons                also passes prior to impacting 226Ra target; and                (ii) maintaining bombardment for a time period                sufficient to remove a neutron and or a proton from                226Ra target and form 225Ac in a commercial                scale.
{USE} - Method for converting 226Ra to 225Ac by                electron beam bombardment with high energy                electrons without the use of a converter.
{ADVANTAGE} - The method has high-purity 226Ra enclosed                target using a high-intensity electron beam                current. This type of production reduces the number                of photons on target. The result is a low                production yield. The efficiency of these methods                is very low, and the designs of such setups are                complex.},
	type = {patentus},
	number = {2025006395-A1},
	author = {{NUSAIR O}},
	urldate = {2025-01-27},
